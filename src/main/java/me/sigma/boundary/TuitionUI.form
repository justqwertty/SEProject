<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="me.sigma.boundary.TuitionUI">
  <grid id="27dc6" binding="mainPanel" default-binding="true" layout-manager="CardLayout" hgap="0" vgap="0">
    <constraints>
      <xy x="20" y="20" width="800" height="600"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <grid id="loginPanel_id" binding="loginPanel" layout-manager="GridLayoutManager" row-count="6" column-count="2" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
        <margin top="40" left="40" bottom="40" right="40"/>
        <constraints>
          <card name="LOGIN"/>
        </constraints>
        <properties/>
        <border type="none"/>
        <children>
          <component id="title_lbl" class="javax.swing.JLabel">
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="2" vsize-policy="0" hsize-policy="0" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <font size="24" style="1"/>
              <horizontalAlignment value="0"/>
              <text value="Tuition Payment System"/>
            </properties>
          </component>
          <component id="subtitle_lbl" class="javax.swing.JLabel">
            <constraints>
              <grid row="1" column="0" row-span="1" col-span="2" vsize-policy="0" hsize-policy="0" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <horizontalAlignment value="0"/>
              <text value="Student Login"/>
            </properties>
          </component>
          <component id="sid_lbl" class="javax.swing.JLabel">
            <constraints>
              <grid row="2" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <text value="Student ID:"/>
            </properties>
          </component>
          <component id="studentIdField" class="javax.swing.JTextField" binding="studentIdField">
            <constraints>
              <grid row="2" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties/>
          </component>
          <component id="pwd_lbl" class="javax.swing.JLabel">
            <constraints>
              <grid row="3" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <text value="Password:"/>
            </properties>
          </component>
          <component id="passwordField" class="javax.swing.JPasswordField" binding="passwordField">
            <constraints>
              <grid row="3" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties/>
          </component>
          <component id="loginButton" class="javax.swing.JButton" binding="loginButton">
            <constraints>
              <grid row="4" column="0" row-span="1" col-span="2" vsize-policy="0" hsize-policy="3" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <font size="14" style="1"/>
              <text value="Login"/>
            </properties>
          </component>
          <component id="statusLabel" class="javax.swing.JLabel" binding="statusLabel">
            <constraints>
              <grid row="5" column="0" row-span="1" col-span="2" vsize-policy="0" hsize-policy="0" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <horizontalAlignment value="0"/>
              <text value=""/>
            </properties>
          </component>
        </children>
      </grid>
      <grid id="paysel_id" binding="paymentSelectionPanel" layout-manager="GridLayoutManager" row-count="6" column-count="2" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
        <margin top="30" left="30" bottom="30" right="30"/>
        <constraints>
          <card name="PAYMENT_SELECTION"/>
        </constraints>
        <properties/>
        <border type="none"/>
        <children>
          <component id="paysel_hdr" class="javax.swing.JLabel">
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="2" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <font size="20" style="1"/>
              <text value="Tuition Payment Details"/>
            </properties>
          </component>
          <component id="bal_title_lbl" class="javax.swing.JLabel">
            <constraints>
              <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <text value="Outstanding Balance:"/>
            </properties>
          </component>
          <component id="balanceLabel" class="javax.swing.JLabel" binding="balanceLabel">
            <constraints>
              <grid row="1" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <font size="16" style="1"/>
              <text value="$0.00"/>
            </properties>
          </component>
          <component id="amt_title_lbl" class="javax.swing.JLabel">
            <constraints>
              <grid row="2" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <text value="Amount Due:"/>
            </properties>
          </component>
          <component id="amountLabel" class="javax.swing.JLabel" binding="amountLabel">
            <constraints>
              <grid row="2" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <font size="16" style="1"/>
              <text value="$0.00"/>
            </properties>
          </component>
          <component id="method_lbl" class="javax.swing.JLabel">
            <constraints>
              <grid row="3" column="0" row-span="1" col-span="2" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <text value="Select Payment Method:"/>
            </properties>
          </component>
          <component id="paymentMethodCombo" class="javax.swing.JComboBox" binding="paymentMethodCombo">
            <constraints>
              <grid row="4" column="0" row-span="1" col-span="2" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties/>
          </component>
          <grid id="paysel_btns" layout-manager="FlowLayout" hgap="20" vgap="0" flow-align="1">
            <constraints>
              <grid row="5" column="0" row-span="1" col-span="2" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties/>
            <border type="none"/>
            <children>
              <component id="proceedButton" class="javax.swing.JButton" binding="proceedButton">
                <constraints/>
                <properties>
                  <font size="14" style="1"/>
                  <text value="Proceed to Payment"/>
                </properties>
              </component>
              <component id="cancelButton" class="javax.swing.JButton" binding="cancelButton">
                <constraints/>
                <properties>
                  <font size="14"/>
                  <text value="Cancel"/>
                </properties>
              </component>
            </children>
          </grid>
        </children>
      </grid>
      <grid id="payproc_id" binding="paymentProcessingPanel" layout-manager="GridLayoutManager" row-count="4" column-count="2" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
        <margin top="40" left="40" bottom="40" right="40"/>
        <constraints>
          <card name="PAYMENT_PROCESSING"/>
        </constraints>
        <properties/>
        <border type="none"/>
        <children>
          <component id="proc_title" class="javax.swing.JLabel">
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="2" vsize-policy="0" hsize-policy="0" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <font size="20" style="1"/>
              <horizontalAlignment value="0"/>
              <text value="Processing Payment"/>
            </properties>
          </component>
          <component id="processingBar" class="javax.swing.JProgressBar" binding="processingBar">
            <constraints>
              <grid row="1" column="0" row-span="1" col-span="2" vsize-policy="0" hsize-policy="6" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <maximum value="100"/>
              <stringPainted value="true"/>
            </properties>
          </component>
          <component id="processingStatus" class="javax.swing.JLabel" binding="processingStatus">
            <constraints>
              <grid row="2" column="0" row-span="1" col-span="2" vsize-policy="0" hsize-policy="0" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <horizontalAlignment value="0"/>
              <text value="Connecting to payment gateway..."/>
            </properties>
          </component>
          <component id="confirmPaymentButton" class="javax.swing.JButton" binding="confirmPaymentButton">
            <constraints>
              <grid row="3" column="0" row-span="1" col-span="2" vsize-policy="0" hsize-policy="3" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <enabled value="false"/>
              <font size="14" style="1"/>
              <text value="Confirm Payment"/>
            </properties>
          </component>
        </children>
      </grid>
      <grid id="receipt_id" binding="receiptPanel" layout-manager="BorderLayout" hgap="10" vgap="10">
        <constraints>
          <card name="RECEIPT"/>
        </constraints>
        <properties/>
        <border type="none"/>
        <children>
          <scrollpane id="receipt_scroll">
            <constraints border-constraint="Center"/>
            <properties/>
            <border type="none"/>
            <children>
              <component id="receiptArea" class="javax.swing.JTextArea" binding="receiptArea">
                <constraints/>
                <properties>
                  <editable value="false"/>
                  <font name="Courier New" size="12"/>
                  <lineWrap value="true"/>
                </properties>
              </component>
            </children>
          </scrollpane>
          <grid id="receipt_btns" layout-manager="FlowLayout" hgap="20" vgap="10" flow-align="1">
            <constraints border-constraint="South"/>
            <properties/>
            <border type="none"/>
            <children>
              <component id="printButton" class="javax.swing.JButton" binding="printButton">
                <constraints/>
                <properties>
                  <font size="14"/>
                  <text value="Print Receipt"/>
                </properties>
              </component>
              <component id="emailButton" class="javax.swing.JButton" binding="emailButton">
                <constraints/>
                <properties>
                  <font size="14"/>
                  <text value="Email Receipt"/>
                </properties>
              </component>
              <component id="doneButton" class="javax.swing.JButton" binding="doneButton">
                <constraints/>
                <properties>
                  <font size="14" style="1"/>
                  <text value="Done"/>
                </properties>
              </component>
            </children>
          </grid>
        </children>
      </grid>
    </children>
  </grid>
</form>
